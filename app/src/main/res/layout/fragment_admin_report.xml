<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Podsumowanie Systemu"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:elevation="2dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wypożyczone" android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="142"
                android:textColor="#008000"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:elevation="2dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Uszkodzone" android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#D32F2F" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:gravity="center"
            android:elevation="2dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Opóźnienia" android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFA500" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Alert: Przetrzymywany sprzęt"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#D32F2F"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="• Jan Kowalski: MacBook Pro M1 (Opóźnienie: 5 dni)\n• Anna Nowak: Rzutnik Epson (Opóźnienie: 2 dni)\n• Tomasz Kot: Klawiatura Keychron (Opóźnienie: 12 dni)"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:lineSpacingExtra="8dp"
        android:elevation="2dp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/buttonGeneratePdf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Generuj Pełny Raport (PDF)" />

</LinearLayout>